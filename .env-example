# ============================================================
# TurnoAI Configuration
# Copia este archivo a .env y llena los valores reales
# ============================================================

# ============================================================
# GOOGLE CALENDAR (MCP - Model Context Protocol)
# ============================================================
# URL del servidor MCP de Google Calendar
# Este debe estar ejecutándose en tu máquina local
# Ejemplo: http://localhost:8000
CALENDAR_MCP_SERVER_URL=http://localhost:8000

# ============================================================
# TWILIO (WhatsApp)
# ============================================================
# Obtén estos valores de https://console.twilio.com

# SID de tu cuenta Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Token de autenticación de tu cuenta Twilio
TWILIO_AUTH_TOKEN=your_auth_token_here

# Número de WhatsApp asignado por Twilio
# Formato: whatsapp:+1234567890
# Ejemplo: whatsapp:+14155552671
TWILIO_WHATSAPP_NUMBER=whatsapp:+your_number_here

# ============================================================
# MODO TESTING (Twilio Fake)
# ============================================================
# Usa modo fake para desarrollo sin enviar mensajes reales
# Valores: true o false
# - true: Los mensajes se imprimen en consola (sin Twilio real)
# - false: Usa credenciales reales de Twilio
USE_TWILIO_FAKE=true

# ============================================================
# OPENAI
# ============================================================
# Tu API Key de OpenAI
# Obtén una en https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# ============================================================
# ZONA HORARIA
# ============================================================
# Zona horaria para interpretar fechas y horas
# Opciones comunes: America/Bogota, America/Mexico_City, America/Buenos_Aires, 
#                   Europe/Madrid, America/New_York, America/Los_Angeles
TIMEZONE=America/Bogota

# ============================================================
# CONFIGURACIÓN DE APLICACIÓN
# ============================================================
# Puerto en el que escucha FastAPI
PORT=8000

# Modo debug
DEBUG=true
